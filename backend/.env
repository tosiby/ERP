# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (Supabase PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_Q97pVxWEiRra@ep-wispy-leaf-ank8bok2-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=verify-full
